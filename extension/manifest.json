{
  "manifest_version": 3,
  "name": "Browser Agent for WS Workspace",
  "version": "2.0.0",
  "description": "Browser automation agent with tab isolation, CDP screenshots, and logged-in session access",

  "permissions": [
    "tabs",
    "tabGroups",
    "activeTab",
    "scripting",
    "debugger",
    "storage",
    "sidePanel"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],

  "action": {}
}
