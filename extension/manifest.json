{
  "manifest_version": 3,
  "name": "Browser Agent for WS Workspace",
  "version": "1.1.0",
  "description": "Browser automation agent with access to logged-in Chrome/Comet sessions",

  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],

  "action": {
    "default_popup": "popup.html"
  }
}
